# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Twilio (Outbound WhatsApp / SMS Notifications) ──────────────────────────
# Get these from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here

# Your Twilio WhatsApp-enabled number (format: whatsapp:+1415XXXXXXX)
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Manager phone number to alert on critical deliveries (format: whatsapp:+27XXXXXXXXX)
MANAGER_ALERT_NUMBER=whatsapp:+27XXXXXXXXX

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
